{
    "name": "LS3",
    "n_gpu": 1,
    "arch": {
        "type": "MVLMModel",
        "args": {
            "n_landmarks": 20,
            "n_features": 256,
            "dropout_rate": 0.2,
            "image_channels": "depth"
        }
    },
    "data_loader": {
        "type": "FaceDataLoader",
        "args": {
            "data_dir": "/mnt/homes/christian.garcia/03_DatosMVCNN_v3_processed/LS3_n25/",
            "heatmap_size": 256,
            "image_size": 256,
            "image_channels": "depth",
            "n_views": 25,
            "batch_size": 4,
            "shuffle": true,
            "validation_split": 0.1,
            "num_workers": 4
        }
    },
    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.001,
            "weight_decay": 0,
            "amsgrad": true
        }
    },
    "loss": "mse_loss",
    "metrics": [
        "my_metric",
        "my_metric2"
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 50,
            "gamma": 0.1
        }
    },
    "trainer": {
        "epochs": 100,
        "save_dir": "__saved/",
        "save_period": 1,
        "verbosity": 2,
        "monitor": "min val_loss",
        "early_stop": 10,
        "tensorboard": true,
        "keepEpochs": false
    },
    "process_3d": {
        "filter_view_lines": "quantile",
        "heatmap_max_quantile": 0.5,
        "heatmap_abs_threshold": 0.5,
        "write_renderings": false,
        "off_screen_rendering": true,
        "min_x_angle": -40,
        "max_x_angle": 40,
        "min_y_angle": -80,
        "max_y_angle": 80,
        "min_z_angle": -20,
        "max_z_angle": 20
    },
    "preparedata": {
        "raw_data_json": "/mnt/homes/christian.garcia/03_DatosMVCNN_v3/LS3_complete.json",
        "processed_data_dir": "/mnt/homes/christian.garcia/03_DatosMVCNN_v3_processed/LS3_complete_n25/",
        "split_data_dir": "/mnt/homes/christian.garcia/03_DatosMVCNN_v3_processed/LS3_n25/",
        "train_file": "LS3_complete_train.txt",
        "test_file": "LS3_complete_test.txt",
        "dump_file": "LS3_complete_all.txt",
        "split": 0.75
    },
    "predict": {
        "model_pth_or_url": "C:\\Users\\alvaro.heredia\\OneDrive - La Salle\\DOCTORADO\\02_Desarrollo\\07_BioFace3D_toGit\\mvcnn\\__configs\\20Landmarks_25views\\model_best.pth"
    },
    "pre-align": {
        "align_center_of_mass": false,
        "rot_x": 0,
        "rot_y": 0,
        "rot_z": 0,
        "scale": 1,
        "write_pre_aligned": false
    }
}
